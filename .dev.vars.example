# OpenAI API key - injected into sandbox requests via the egress proxy.
# Never enters the container.
OPENAI_API_KEY=sk-...

# Anthropic credentials for running Claude Code (`sclaude`) inside the sandbox.
# Injected via the egress proxy; never enters the container.
#
# Subscription auth: a long-lived OAuth token from `claude setup-token`
# (sk-ant-oat01-...). Billed against your Pro/Max plan's agentic usage limits.
# CLAUDE_CODE_OAUTH_TOKEN=sk-ant-oat01-...
#
# API-key auth (alternative): usage-based billing on your Platform account.
# ANTHROPIC_API_KEY=sk-ant-...

# Optional: bearer token for WebSocket auth. If set, clients must provide
# Authorization: Bearer <token> header or ?token=<token> query param.
# AUTH_TOKEN=your-secret-token

# GitHub PAT - injected into github.com requests via the egress proxy.
# Needed for private repo cloning from inside the sandbox.
# GITHUB_TOKEN=ghp_...

# How long the sandbox container stays alive after the last request.
# Accepts durations like '1m', '5m', '1h'. Default: 1m.
# SANDBOX_SLEEP_AFTER=1m
